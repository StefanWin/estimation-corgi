    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/geist": "5.3.0",
    "@fontsource-variable/geist-mono": "5.3.0",
    "@marsidev/react-turnstile": "1.5.3",
    "@mui/material": "^9.2.0",
    "convex": "1.42.3",
    "lucide-react": "0.577.0",
    "posthog-js": "1.403.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@cloudflare/vite-plugin": "^1.13.14",
    "@cloudflare/workers-types": "^5.20260723.1",
    "@types/node": "26.1.1",
