{
  "name": "estimation-corgi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --parallel dev:next dev:convex",
    "dev:next": "next dev",
    "dev:convex": "convex dev",
    "build": "next build",
    "start": "next start",
    "types": "next typegen && tsc --noEmit",
